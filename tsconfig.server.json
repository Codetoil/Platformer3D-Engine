{
  "compilerOptions": {
    "module": "es2022",
    "strict": true,
    "alwaysStrict": true,
    "noImplicitOverride": true,
    "preserveConstEnums": true,
    "composite": true,
    "outDir": "dist",
    "sourceMap": true,
    "lib": ["ES2023", "WebWorker"]
  },
  "include": [
    "src/ts/server/runServer.ts",
    "src/ts/server/*",
    "src/ts/common/*",
    "src/ts/math/*",
    "src/ts/levelpack/levelpack.ts"
  ]
}